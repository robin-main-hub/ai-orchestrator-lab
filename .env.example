DGX_SERVER_BASE_URL=https://orchestrator.endruin.com
VITE_DGX_SERVER_BASE_URL=https://orchestrator.endruin.com

# LAN fallback used by the desktop runtime when the public endpoint is not ready.
DGX_SERVER_LAN_BASE_URL=http://dgx-02:4317

# Bearer token required by every server endpoint except /health and OPTIONS preflight.
# In NODE_ENV=production the server refuses to start without this set.
# In development a dev fallback ("dev-orchestrator-token") is used with a console warning.
ORCHESTRATOR_API_TOKEN=replace-with-strong-random-token
# Same token exposed to the desktop client so it can attach the Authorization header.
VITE_ORCHESTRATOR_API_TOKEN=replace-with-strong-random-token

