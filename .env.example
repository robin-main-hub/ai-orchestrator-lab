DGX_SERVER_BASE_URL=https://orchestrator.endruin.com
VITE_DGX_SERVER_BASE_URL=https://orchestrator.endruin.com

# LAN fallback used by the desktop runtime when the public endpoint is not ready.
DGX_SERVER_LAN_BASE_URL=http://dgx-02:4317
VITE_DGX_SERVER_LAN_BASE_URL=http://dgx-02:4317

# Optional comma-separated desktop fallback override. For local dry-run smoke tests,
# set VITE_DGX_SERVER_BASE_URL=http://127.0.0.1:4317 and leave this empty.
# VITE_DGX_SERVER_FALLBACK_BASE_URLS=http://dgx-02:4317,https://orchestrator.endruin.com

# Bearer token required by every server endpoint except /health and OPTIONS preflight.
# In NODE_ENV=production the server refuses to start without this set.
# In development a dev fallback ("dev-orchestrator-token") is used with a console warning.
ORCHESTRATOR_API_TOKEN=replace-with-strong-random-token
# Same token exposed to the desktop client so it can attach the Authorization header.
VITE_ORCHESTRATOR_API_TOKEN=replace-with-strong-random-token

# MiMo Token Plan API key used by seeded MiMo provider profiles.
# Keep the real key in local .env or DGX vault only; never commit it.
MIMO_API_KEY=replace-with-mimo-token-plan-key

# tmux smoke mode: approval + redispatch can be tested without touching real tmux
# panes or the DGX-02 local model engine. Approved dispatches are recorded and
# returned as dry-run accepted instead of executing send-keys.
# ORCHESTRATOR_TMUX_DRY_RUN=1

# Comma-separated extra origins to allow in CORS, on top of the built-in
# defaults (localhost:5173, 127.0.0.1:5173, localhost:5174, 127.0.0.1:5174,
# https://orchestrator.endruin.com). Use this for additional dev ports or
# preview deployments without rebuilding.
# ORCHESTRATOR_ALLOWED_ORIGINS=http://localhost:5175,https://staging.orchestrator.endruin.com
