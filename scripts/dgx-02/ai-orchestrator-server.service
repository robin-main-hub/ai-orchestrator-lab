[Unit]
Description=AI Orchestrator Lab DGX-02 server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/robin/ai-orchestrator-lab
Environment=PORT=4317
Environment=DGX02_VLLM_BASE_URL=http://127.0.0.1:8001/v1
ExecStart=/usr/bin/env bash /home/robin/ai-orchestrator-lab/scripts/dgx-02/run-server.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
