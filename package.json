{
  "name": "ai-orchestrator-lab",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "pnpm --filter @ai-orchestrator/desktop dev",
    "build": "pnpm -r --sort build",
    "typecheck": "pnpm --filter @ai-orchestrator/protocol build && pnpm --filter @ai-orchestrator/providers build && pnpm --filter @ai-orchestrator/memory build && pnpm --filter @ai-orchestrator/agents build && pnpm --filter @ai-orchestrator/server typecheck && pnpm --filter @ai-orchestrator/desktop typecheck",
    "test": "pnpm build && pnpm -r --if-present test",
    "lint": "pnpm typecheck",
    "clean": "node scripts/clean-workspace.mjs",
    "server:build": "pnpm --filter @ai-orchestrator/server build",
    "server:start": "pnpm --filter @ai-orchestrator/server start",
    "server:smoke": "node scripts/smoke-dgx-server.mjs",
    "tmux:smoke:dry-run": "node scripts/smoke-tmux-dry-run.mjs",
    "antigravity:ultra-task": "node scripts/create-antigravity-ultra-task.mjs",
    "antigravity:pro1-task": "node scripts/create-antigravity-pro1-task.mjs",
    "antigravity:pro2-task": "node scripts/create-antigravity-pro2-task.mjs",
    "antigravity:worker": "node scripts/run-antigravity-worker.mjs",
    "antigravity:smoke": "node scripts/smoke-antigravity-worker.mjs",
    "personal-ai:sessions": "node scripts/check-personal-ai-sessions.mjs",
    "personal-ai:smoke": "node scripts/smoke-personal-ai-sessions.mjs",
    "swarm:setup": "bash scripts/setup-agent-swarm.sh",
    "swarm:reset": "bash scripts/setup-agent-swarm.sh --reset",
    "swarm:send": "bash scripts/swarm-send.sh",
    "swarm:capture": "bash scripts/swarm-capture.sh",
    "swarm:claude:start": "bash scripts/swarm-start-claude-workers.sh",
    "swarm:claude:task": "bash scripts/swarm-claude-task.sh"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
